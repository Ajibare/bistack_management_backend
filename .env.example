# Copy this file to .env for local dev. For production, set the same
# variables in your hosting provider's dashboard (e.g. Vercel project
# settings -> Environment Variables).

# MongoDB connection string
# Local:    mongodb://localhost:27017/bigstack_management
# Atlas:    mongodb+srv://<user>:<db_password>@<cluster>.mongodb.net/bigstack_management?appName=<cluster>
MONGO_URI=mongodb://localhost:27017/bigstack_management

PORT=3001

# SMTP configuration for sending invoice emails and reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@bigstack.com

# Optional: reminder check interval in milliseconds (default 86400000 = 24h)
REMINDER_CHECK_INTERVAL_MS=86400000
